---
type Props = {
	href: string;
	title: string;
	description: string;
	pubDate: Date;
	category: string;
	tags: string[];
};

const { href, title, description, pubDate, category, tags } = Astro.props;
const date = new Intl.DateTimeFormat('ja-JP', { year: 'numeric', month: 'short', day: 'numeric' }).format(pubDate);
---

<a class="post-card group" href={href}>
	<p class="eyebrow">{category} / {date}</p>
	<h2 class="mt-3 text-xl font-semibold text-white">{title}</h2>
	<p class="mt-4 text-sm leading-7 text-neutral-400">{description}</p>
	<div class="mt-6 flex flex-wrap gap-2">
		{tags.map((tag) => <span class="tag">#{tag}</span>)}
	</div>
	<span class="mt-7 inline-flex text-sm font-medium text-neutral-200 transition group-hover:translate-x-1">
		Read note
	</span>
</a>
