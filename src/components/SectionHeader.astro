---
type Props = {
	eyebrow?: string;
	title: string;
	description?: string;
};

const { eyebrow, title, description } = Astro.props;
---

<div class="section-header">
	{eyebrow && <p class="eyebrow">{eyebrow}</p>}
	<h1>{title}</h1>
	{description && <p class="section-lead">{description}</p>}
</div>
