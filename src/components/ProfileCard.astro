---
const current = ['Steamゲームデータ分析', 'Astroポートフォリオサイト', 'VRワールド制作'];
const stack = ['React', 'TypeScript', 'Astro', 'Python', 'Unity'];
---

<aside class="profile-card">
	<div class="flex items-center gap-4">
		<div class="avatar-frame" aria-hidden="true">
			<span>R</span>
		</div>
		<div>
			<p class="eyebrow">Profile</p>
			<h2 class="mt-2 text-xl font-semibold text-white">Roki Works</h2>
			<p class="mt-1 text-sm text-slate-400">Student developer building small products and visual experiments.</p>
		</div>
	</div>
	<div class="mt-7 grid gap-6 md:grid-cols-2 lg:grid-cols-1">
		<div>
			<h3 class="text-sm font-semibold text-slate-200">現在取り組んでいること</h3>
			<ul class="mt-3 space-y-2 text-sm text-slate-400">
				{current.map((item) => <li class="flex gap-2"><span class="mt-2 h-1.5 w-1.5 rounded-full bg-sky-300"></span>{item}</li>)}
			</ul>
		</div>
		<div>
			<h3 class="text-sm font-semibold text-slate-200">使用技術</h3>
			<div class="mt-3 flex flex-wrap gap-2">
				{stack.map((item) => <span class="tag">{item}</span>)}
			</div>
		</div>
	</div>
</aside>
