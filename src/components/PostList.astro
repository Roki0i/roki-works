---
type Post = {
	id: string;
	data: {
		title: string;
		description: string;
		pubDate: Date;
		category: string;
		tags: string[];
	};
};

type Props = {
	posts: Post[];
	limit?: number;
};

const { posts, limit } = Astro.props;
const visiblePosts = typeof limit === 'number' ? posts.slice(0, limit) : posts;
const formatDate = (date: Date) =>
	new Intl.DateTimeFormat('ja-JP', { year: 'numeric', month: 'short', day: 'numeric' }).format(date);
---

<div class="post-list">
	{visiblePosts.map((post) => (
		<a class="post-list-item group" href={`/blog/${post.id}/`}>
			<div class="flex flex-wrap items-center gap-3 text-xs font-semibold uppercase tracking-[0.16em] text-slate-500">
				<span class="text-sky-200/80">{post.data.category}</span>
				<span>{formatDate(post.data.pubDate)}</span>
			</div>
			<h3 class="mt-3 text-xl font-semibold tracking-tight text-white md:text-2xl">{post.data.title}</h3>
			<p class="mt-3 max-w-3xl text-sm leading-7 text-slate-400">{post.data.description}</p>
			<div class="mt-4 flex flex-wrap gap-2">
				{post.data.tags.map((tag) => <span class="tag">#{tag}</span>)}
			</div>
		</a>
	))}
</div>
