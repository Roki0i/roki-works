---
import Layout from '../layouts/Layout.astro';
import WorkCard from '../components/WorkCard.astro';
import PostCard from '../components/PostCard.astro';
import StatusBadge from '../components/StatusBadge';
import { getCollection } from 'astro:content';

const works = (await getCollection('works'))
	.sort((a, b) => a.data.order - b.data.order)
	.slice(0, 3);
const posts = (await getCollection('blog', ({ data }) => !data.draft))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 2);
---

<Layout title="Roki Works" description="Roki Worksは制作物と制作ログをまとめるポートフォリオ兼ブログです。">
	<section class="page-section">
		<div class="grid gap-12 lg:grid-cols-[1.1fr_0.9fr] lg:items-end">
			<div>
				<div class="mb-7">
					<StatusBadge label="Portfolio / Blog / Build log" />
				</div>
				<p class="eyebrow">Roki Works</p>
				<h1 class="mt-4 max-w-4xl text-5xl font-bold leading-[0.98] tracking-[-0.045em] text-white md:text-7xl">
					Quiet interface, practical prototypes, and notes from the build.
				</h1>
				<p class="mt-7 max-w-2xl text-base leading-8 text-neutral-400 md:text-lg">
					Web、VR、データ可視化、ガジェットまわりの制作物と記録をまとめる場所です。就活ポートフォリオとして見やすく、更新しやすい構成にしています。
				</p>
				<div class="mt-9 flex flex-wrap gap-3">
					<a class="rounded-full bg-white px-5 py-3 text-sm font-semibold text-neutral-950 transition hover:bg-neutral-200" href="/works/">View Works</a>
					<a class="rounded-full border border-white/15 px-5 py-3 text-sm font-semibold text-white transition hover:border-white/35 hover:bg-white/10" href="/blog/">Read Blog</a>
				</div>
			</div>
			<div class="rounded-lg border border-white/10 bg-white/[0.035] p-5">
				<p class="eyebrow">Focus</p>
				<div class="mt-5 grid gap-3">
					{['Astro + React', 'Tailwind CSS', 'Markdown / MDX', 'Cloudflare Pages / Vercel ready'].map((item) => (
						<div class="flex items-center justify-between border-b border-white/10 py-3 text-sm text-neutral-300 last:border-0">
							<span>{item}</span>
							<span class="text-neutral-500">Ready</span>
						</div>
					))}
				</div>
			</div>
		</div>
	</section>

	<section class="page-section pt-0">
		<div class="mb-8 flex items-end justify-between gap-6">
			<div>
				<p class="eyebrow">Selected Works</p>
				<h2 class="mt-3 text-3xl font-semibold tracking-tight text-white md:text-4xl">制作物</h2>
			</div>
			<a class="hidden text-sm font-medium text-neutral-300 hover:text-white md:inline" href="/works/">All works</a>
		</div>
		<div class="grid gap-4 md:grid-cols-3">
			{works.map((work) => (
				<WorkCard
					href={`/works/${work.id}/`}
					title={work.data.title}
					summary={work.data.summary}
					category={work.data.category}
					year={work.data.year}
					stack={work.data.stack}
					status={work.data.status}
				/>
			))}
		</div>
	</section>

	<section class="page-section pt-0">
		<div class="mb-8 flex items-end justify-between gap-6">
			<div>
				<p class="eyebrow">Recent Blog</p>
				<h2 class="mt-3 text-3xl font-semibold tracking-tight text-white md:text-4xl">制作ログとガジェット記事</h2>
			</div>
			<a class="hidden text-sm font-medium text-neutral-300 hover:text-white md:inline" href="/blog/">All posts</a>
		</div>
		<div class="grid gap-4 md:grid-cols-2">
			{posts.map((post) => (
				<PostCard
					href={`/blog/${post.id}/`}
					title={post.data.title}
					description={post.data.description}
					pubDate={post.data.pubDate}
					category={post.data.category}
					tags={post.data.tags}
				/>
			))}
		</div>
	</section>
</Layout>
