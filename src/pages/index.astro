---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import ProfileCard from '../components/ProfileCard.astro';
import PostList from '../components/PostList.astro';
import SectionHeading from '../components/SectionHeading.astro';
import WorkCard from '../components/WorkCard.astro';
import { getCollection } from 'astro:content';

const works = (await getCollection('works'))
	.sort((a, b) => a.data.order - b.data.order)
	.slice(0, 3);
const posts = (await getCollection('blog', ({ data }) => !data.draft))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);
---

<Layout title="Roki Works" description="Roki Worksは個人開発者の制作ログ兼ブログです。">
	<Hero />

	<section class="page-section pt-0">
		<div class="grid gap-10 lg:grid-cols-[1fr_20rem]">
			<div>
				<div class="mb-8 flex items-end justify-between gap-6">
					<SectionHeading
						eyebrow="Latest Posts"
						title="制作ログ"
						description="実装メモ、制作途中の判断、ガジェットや作業環境の記録を新しい順に並べています。"
					/>
					<a class="hidden text-sm font-medium text-slate-300 hover:text-white md:inline" href="/blog/">All posts</a>
				</div>
				<PostList posts={posts} />
			</div>
			<ProfileCard />
		</div>
	</section>

	<section class="page-section pt-0">
		<div class="mb-8 flex items-end justify-between gap-6">
			<SectionHeading
				eyebrow="Featured Works"
				title="代表作品"
				description="制作ログから派生したプロトタイプと可視化アイデアです。"
			/>
			<a class="hidden text-sm font-medium text-slate-300 hover:text-white md:inline" href="/works/">All works</a>
		</div>
		<div class="grid gap-4 md:grid-cols-3">
			{works.map((work) => (
				<WorkCard
					href={`/works/${work.id}/`}
					title={work.data.title}
					summary={work.data.summary}
					category={work.data.category}
					year={work.data.year}
					stack={work.data.stack}
					status={work.data.status}
				/>
			))}
		</div>
	</section>

	<section class="page-section pt-0">
		<div class="newsletter-panel">
			<div>
				<p class="eyebrow">Newsletter</p>
				<h2 class="mt-3 text-2xl font-semibold tracking-tight text-white md:text-3xl">制作ログやガジェットメモを更新していきます</h2>
				<p class="mt-4 max-w-2xl text-sm leading-7 text-slate-400">
					実際の送信機能はまだありません。あとでニュースレターや更新通知を追加できるように、入力欄風のUIだけ置いています。
				</p>
			</div>
			<form class="mt-7 flex flex-col gap-3 sm:flex-row" aria-label="Newsletter mock form">
				<input class="mock-input" type="email" placeholder="you@example.com" disabled />
				<button class="primary-button opacity-80" type="button" disabled>Notify me</button>
			</form>
		</div>
	</section>
</Layout>
