---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
	const posts = await getCollection('blog', ({ data }) => !data.draft);
	return posts.map((post) => ({
		params: { slug: post.id },
		props: { post },
	}));
}

const { post } = Astro.props;
const { Content } = await render(post);
const date = new Intl.DateTimeFormat('ja-JP', { year: 'numeric', month: 'long', day: 'numeric' }).format(post.data.pubDate);
---

<Layout title={post.data.title} description={post.data.description}>
	<article class="page-section">
		<a class="text-sm text-neutral-400 hover:text-white" href="/blog/">← Blog</a>
		<header class="mt-10 max-w-3xl">
			<p class="eyebrow">{post.data.category} / {date}</p>
			<h1 class="mt-4 text-5xl font-bold leading-tight tracking-[-0.04em] text-white md:text-6xl">{post.data.title}</h1>
			<p class="mt-6 text-lg leading-8 text-neutral-400">{post.data.description}</p>
			<div class="mt-6 flex flex-wrap gap-2">
				{post.data.tags.map((tag) => <span class="tag">#{tag}</span>)}
			</div>
		</header>
		<div class="prose mt-12 max-w-3xl">
			<Content />
		</div>
	</article>
</Layout>
