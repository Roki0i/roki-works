---
import Layout from '../../layouts/Layout.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import WorkCard from '../../components/WorkCard.astro';
import { getCollection } from 'astro:content';

const works = (await getCollection('works')).sort((a, b) => a.data.order - b.data.order);
---

<Layout title="Works" description="Roki Worksの制作物一覧です。">
	<section class="page-section">
		<SectionHeading
			eyebrow="Works"
			title="制作物とプロトタイプ"
			description="VR、データ可視化、分析メモを、プロダクトとしての狙い、状態、使用技術が伝わる形で整理しています。"
		/>
		<div class="mt-12 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
			{works.map((work) => (
				<WorkCard
					href={`/works/${work.id}/`}
					title={work.data.title}
					summary={work.data.summary}
					category={work.data.category}
					year={work.data.year}
					stack={work.data.stack}
					status={work.data.status}
				/>
			))}
		</div>
	</section>
</Layout>
